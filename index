<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Minasfac — Fomento Mercantil</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:#0D0D0D;color:#F0EDE6;overflow-x:hidden;}
:root{
  --red:#C0271F;
  --gold:#C9A96E;
  --gold-light:#E8C98A;
  --dark:#0D0D0D;
  --dark-2:#141414;
  --dark-3:#1C1C1C;
  --gray:#8A8780;
  --light:#F0EDE6;
  --light-muted:#B8B4AC;
}

/* ── NAV ── */
nav{
  position:fixed;top:0;width:100%;z-index:200;
  background:rgba(13,13,13,0.92);
  border-bottom:1px solid rgba(201,169,110,0.12);
  padding:0 60px;
  display:flex;align-items:center;justify-content:space-between;
  height:72px;
  backdrop-filter:blur(12px);
  transition:background 0.3s;
}
.nav-logo{display:flex;align-items:center;gap:14px;text-decoration:none;}
.nav-logo-name{font-family:'DM Sans',sans-serif;font-weight:500;font-size:18px;letter-spacing:0.18em;color:var(--light);line-height:1;}
.nav-logo-sub{font-size:9px;letter-spacing:0.28em;text-transform:uppercase;color:var(--gold);margin-top:3px;}
.nav-links{display:flex;gap:36px;list-style:none;}
.nav-links a{font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--light-muted);text-decoration:none;transition:color 0.2s;}
.nav-links a:hover{color:var(--gold);}
.nav-cta{background:var(--red);color:var(--light);border:none;cursor:pointer;padding:11px 26px;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;font-family:'DM Sans',sans-serif;transition:opacity 0.2s;}
.nav-cta:hover{opacity:0.85;}

/* ── HERO ── */
.hero{
  min-height:100vh;
  position:relative;
  display:flex;align-items:flex-end;
  overflow:hidden;
}
.hero-img{
  position:absolute;inset:0;
  background-size:cover;background-position:center 30%;
  filter:brightness(0.45) saturate(0.8);
  transform:scale(1.03);
  transition:transform 8s ease;
}
.hero:hover .hero-img{transform:scale(1);}
.hero-overlay{
  position:absolute;inset:0;
  background:linear-gradient(
    to bottom,
    rgba(13,13,13,0.2) 0%,
    rgba(13,13,13,0.1) 40%,
    rgba(13,13,13,0.75) 75%,
    rgba(13,13,13,0.97) 100%
  );
}
.hero-overlay-left{
  position:absolute;inset:0;
  background:linear-gradient(to right, rgba(13,13,13,0.7) 0%, transparent 55%);
}
.hero-content{
  position:relative;z-index:2;
  padding:0 60px 90px;
  max-width:700px;
}
.hero-eyebrow{
  font-size:11px;letter-spacing:0.32em;text-transform:uppercase;
  color:var(--gold);margin-bottom:20px;
  display:flex;align-items:center;gap:14px;
  opacity:0;animation:fadeUp 0.8s 0.2s forwards;
}
.hero-eyebrow::before{content:'';display:block;width:36px;height:1px;background:var(--gold);}
.hero-title{
  font-family:'Playfair Display',serif;
  font-size:clamp(40px,5.5vw,72px);
  line-height:1.08;color:var(--light);
  margin-bottom:22px;
  opacity:0;animation:fadeUp 0.8s 0.4s forwards;
}
.hero-title em{color:var(--gold);font-style:normal;}
.hero-subtitle{
  font-size:17px;line-height:1.75;color:rgba(240,237,230,0.75);
  max-width:480px;margin-bottom:44px;font-weight:300;
  opacity:0;animation:fadeUp 0.8s 0.6s forwards;
}
.hero-buttons{
  display:flex;gap:14px;flex-wrap:wrap;
  opacity:0;animation:fadeUp 0.8s 0.8s forwards;
}
.btn-primary{background:var(--red);color:var(--light);padding:16px 34px;font-size:12px;letter-spacing:0.1em;text-transform:uppercase;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;text-decoration:none;display:inline-block;transition:opacity 0.2s;}
.btn-primary:hover{opacity:0.85;}
.btn-outline{background:transparent;color:var(--gold);padding:16px 34px;font-size:12px;letter-spacing:0.1em;text-transform:uppercase;border:1px solid rgba(201,169,110,0.4);cursor:pointer;font-family:'DM Sans',sans-serif;text-decoration:none;display:inline-block;transition:border-color 0.2s,color 0.2s;}
.btn-outline:hover{border-color:var(--gold);color:var(--gold-light);}

.hero-stats{
  position:absolute;right:60px;bottom:80px;z-index:2;
  display:flex;gap:52px;
  opacity:0;animation:fadeUp 0.8s 1s forwards;
}
.stat{text-align:right;}
.stat-num{font-family:'Playfair Display',serif;font-size:42px;color:var(--gold);line-height:1;}
.stat-label{font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:rgba(201,169,110,0.6);margin-top:6px;}

/* ── SECTION COMMON ── */
.section-label{font-size:10px;letter-spacing:0.32em;text-transform:uppercase;color:var(--gold);margin-bottom:10px;display:flex;align-items:center;gap:12px;}
.section-label::before{content:'';display:block;width:28px;height:1px;background:var(--gold);}
.section-title{font-family:'Playfair Display',serif;font-size:clamp(26px,3vw,40px);color:var(--light);margin-bottom:52px;line-height:1.2;}
.divider{height:1px;background:linear-gradient(90deg,transparent,rgba(201,169,110,0.2),transparent);margin:0 60px;}

/* ── SERVICES ── */
.services{padding:96px 60px;background:var(--dark-2);}
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(201,169,110,0.07);}
.service-card{background:var(--dark-2);padding:44px 36px;border-top:2px solid transparent;transition:border-color 0.3s,background 0.3s;cursor:default;}
.service-card:hover{border-top-color:var(--red);background:#181818;}
.service-icon{margin-bottom:28px;}
.service-name{font-family:'Playfair Display',serif;font-size:20px;color:var(--light);margin-bottom:14px;}
.service-desc{font-size:14px;line-height:1.8;color:var(--gray);font-weight:300;}
.service-link{display:inline-flex;align-items:center;gap:8px;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold);margin-top:28px;text-decoration:none;transition:gap 0.2s;}
.service-link:hover{gap:14px;}
.service-link::after{content:'→';}

/* ── ABOUT ── */
.about{padding:96px 60px;background:var(--dark);display:grid;grid-template-columns:1fr 1fr;gap:96px;align-items:center;}
.about-visual{position:relative;height:420px;}
.about-bg{position:absolute;top:0;left:0;width:80%;height:82%;background:var(--dark-3);border:1px solid rgba(201,169,110,0.1);}
.about-red{position:absolute;bottom:0;right:0;width:46%;height:46%;background:var(--red);display:flex;flex-direction:column;align-items:center;justify-content:center;}
.about-year{font-family:'Playfair Display',serif;font-size:52px;color:#fff;line-height:1;}
.about-year-sub{font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.5);margin-top:4px;}
.about-logo-mark{position:absolute;top:50%;left:36%;transform:translate(-50%,-50%);opacity:0.05;}
.about-anfac{position:absolute;top:20px;right:20px;background:rgba(201,169,110,0.07);border:1px solid rgba(201,169,110,0.2);padding:10px 18px;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:var(--gold);}
.about-body{font-size:15px;line-height:1.85;color:var(--light-muted);font-weight:300;margin-bottom:28px;}

/* ── CONTACT STRIP ── */
.contact-strip{background:var(--dark-3);border-top:1px solid rgba(201,169,110,0.1);border-bottom:1px solid rgba(201,169,110,0.1);padding:52px 60px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:36px;}
.contact-label{font-size:10px;letter-spacing:0.28em;text-transform:uppercase;color:var(--gold);margin-bottom:8px;}
.contact-title{font-family:'Playfair Display',serif;font-size:28px;color:var(--light);}
.contact-phones{display:flex;gap:48px;flex-wrap:wrap;}
.phone-num{font-size:15px;color:var(--light);font-weight:500;letter-spacing:0.03em;}
.phone-note{font-size:11px;color:var(--gray);margin-top:3px;}

/* ── FOOTER ── */
footer{background:#080808;padding:48px 60px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:28px;border-top:1px solid rgba(255,255,255,0.04);}
.footer-logo-wrap{display:flex;align-items:center;gap:14px;}
.footer-logo-name{font-family:'DM Sans',sans-serif;font-weight:500;font-size:15px;letter-spacing:0.18em;color:var(--light-muted);}
.footer-logo-sub{font-size:9px;letter-spacing:0.2em;color:var(--gray);text-transform:uppercase;margin-top:3px;}
.footer-address{font-size:12px;color:var(--gray);line-height:1.8;}
.footer-mail{font-size:13px;color:var(--gold);text-decoration:none;}
.footer-mail:hover{color:var(--gold-light);}
.footer-copy{font-size:11px;color:rgba(138,135,128,0.38);}

/* ── ANIMATIONS ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a class="nav-logo" href="#">
    <svg width="42" height="42" viewBox="0 0 80 80" fill="none">
      <polygon points="40,4 74,22 74,58 40,76 6,58 6,22" fill="#C0271F"/>
