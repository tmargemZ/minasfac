      <a class="service-link" href="#contato">Saiba mais</a>
    </div>
    <div class="service-card">
      <div class="service-icon">
        <svg width="38" height="38" viewBox="0 0 38 38" fill="none">
          <rect x="5" y="5" width="28" height="28" rx="2" stroke="#C0271F" stroke-width="1.4"/>
          <path d="M19 10V28M10 19H28" stroke="#C9A96E" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="service-name">Antecipação de Crédito</div>
      <div class="service-desc">Antecipe duplicatas, cheques e contratos com agilidade. Operações rápidas, taxas competitivas e relacionamento direto.</div>
      <a class="service-link" href="#contato">Saiba mais</a>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ABOUT -->
<section class="about" id="sobre">
  <div class="about-visual">
    <div class="about-bg"></div>
    <div class="about-logo-mark">
      <svg width="130" height="130" viewBox="0 0 80 80" fill="none">
        <polygon points="40,4 74,22 74,58 40,76 6,58 6,22" fill="white"/>
        <polygon points="40,18 62,58 18,58" fill="#141414"/>
