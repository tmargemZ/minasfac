<!-- HERO -->
<section class="hero">
  <div class="hero-img" id="heroImg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-overlay-left"></div>
  <div class="hero-content">
    <div class="hero-eyebrow">Fomento Mercantil no Rio de Janeiro</div>
    <h1 class="hero-title">Crédito ágil para<br>empresas que <em>não param</em>.</h1>
    <p class="hero-subtitle">Desde 1996, a Minasfac conecta indústria e comércio ao capital de giro que precisam — com transparência, rapidez e solidez.</p>
    <div class="hero-buttons">
      <a class="btn-primary" href="#servicos">Antecipar crédito</a>
      <a class="btn-outline" href="#sobre">Conheça a Minasfac</a>
